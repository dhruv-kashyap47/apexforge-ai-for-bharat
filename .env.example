# PostgreSQL Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/apexforge_db

# Optional: For cloud deployments
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=apexforge_db
# DB_USER=your_username
# DB_PASSWORD=your_password

# App Configuration
APP_TITLE=ApexForge AI - Unified Business Identity System
APP_VERSION=1.0.0
DEBUG=false

# Optional Gemini configuration for AI-assisted explanations
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=12
GEMINI_MAX_OUTPUT_TOKENS=160
GEMINI_MIN_CALL_GAP_SECONDS=1.2
GEMINI_CACHE_TTL_SECONDS=604800
